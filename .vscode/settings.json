{
  "workspaceTasks.act.envFile": "",
  "workspaceTasks.applicationPath.maven": "tools/maven/bin/mvn",
  "workspaceTasks.groups.recentTasks.enabled": false,

  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe", // Path might vary
      "args": [
        "-noprofile"
      ]
    },
  },
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "workspaceTasks.groups.compoundTasks.enabled": true,
  "workspaceTasks.debug": true,
  "workspaceTasks.envVars.env": {
    "TEST_TOKEN": "ABCD"
  },
  "workspaceTasks.envVars.taskEnv": [
    {
      "match": {
        "taskType": "makefile",
        "taskName": "test"
      },
      "secrets": {
        "MY_TEST_TOKEN": "test-api-key",
        "NO_TEST_TOKEN": "this-doesnt-exist"
      },
      "secretFiles": [
        ".secrets"
      ]
    }
  ],
  "workspaceTasks.envVars.envFiles": {
    "include": [".env-warn"]
  },
  "workspaceTasks.groups.useParentFolder": true,
  "workspaceTasks.secrets.showEmptyGroup": true,
  "workspaceTasks.shellEnabledTaskTypes": {
    "extensionless": true
  },
  "workspaceTasks.envVars.warnIfGitTracked": true,
  "workspaceTasks.recentTasks.maxItems": 5,
  "workspaceTasks.task.confirmPatterns": [
    "env-.*"
  ],
  "workspaceTasks.enabledTaskTypes": {
    "ruby": true,
    "gitlab-ci": true,
    "circleci": true
  },
  "workspaceTasks.taskDiscovery.fetchDepth": 4,
  "workspaceTasks.task.guidedArgInput": true,
  "workspaceTasks.groups.taskSeparatorIsRegex": true,
  "workspaceTasks.groups.taskSeparator": ":|/|-|\\s"
}
