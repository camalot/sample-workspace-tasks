{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "cache_duration": "none"
          },
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "foreground": "#26C6DA",
          "powerline_symbol": "\ue0b0",
          "background": "#546E7A",
          "type": "os",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none"
          },
          "leading_diamond": "\ue0b0",
          "trailing_diamond": "\ue0b0",
          "foreground": "#111111",
          "powerline_symbol": "\ue0b0",
          "background": "#FFD664",
          "type": "upgrade",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none"
          },
          "leading_diamond": "\ue0b0",
          "trailing_diamond": "\ue0b0",
          "template": " {{ if .SSHSession }}\uf817 {{ end }}{{ .UserName }}{{ if .SSHSession }}@{{.HostName}}{{ end }} ",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#c386f1",
          "type": "session",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none",
            "style": "folder"
          },
          "trailing_diamond": "\ue0b0",
          "template": " \ue5ff {{ .Path }} ",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#ff479c",
          "type": "path",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "mapped_branches": {
              "beta": "🐭 ",
              "beta/*": "🐭 ",
              "bug/*": "🐛 ",
              "feat/*": "\ud83d\ude80 "
            },
            "source": "cli",
            "untracked_modes": {
              "/Users/user/Projects/oh-my-posh/": "no"
            }
          },
          "template": " {{ .UpstreamIcon }} {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \uf0c7 {{ .StashCount }}{{ end }} ",
          "foreground": "#193549",
          "powerline_symbol": "\ue0b0",
          "background": "#8722c2",
          "type": "git",
          "style": "powerline",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#d14006{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#044707{{ end }}",
            "{{ if gt .Ahead 0 }}#8722c2{{ end }}",
            "{{ if gt .Behind 0 }}#f1b612{{ end }}"
          ]
        },
        {
          "options": {
            "cache_duration": "none",
            "fetch_version": true
          },
          "template": " \ue70c {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }} ",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#6CA35E",
          "type": "dotnet",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none",
            "display_default": true,
            "display_mode": "environment",
            "fetch_version": true,
            "fetch_virtual_env": true,
            "prefix": "\ue73c "
          },
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "foreground": "#000000",
          "powerline_symbol": "\ue0b0",
          "background": "#346a9a",
          "type": "python",
          "style": "powerline"
        },
        {
          "options": {
            "cache_duration": "none"
          },
          "template": " \uf0e7 ",
          "foreground": "#111111",
          "powerline_symbol": "\ue0b0",
          "background": "#ffff66",
          "type": "root",
          "style": "powerline"
        },
        {
          "options": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": " \ue23a{{ if gt .Code 0}} \uf00d{{ else }} \uf42e{{ end }} ",
          "foreground": "#ffffff",
          "powerline_symbol": "\ue0b0",
          "background": "#2e9599",
          "type": "status",
          "style": "powerline",
          "background_templates": ["{{ if gt .Code 0 }}#f1184c{{ end }}"]
        }
      ]
    }
  ],
  "version": 4,
  "final_space": true
}
